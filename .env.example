# Search settings
MAX_SEARCH_RESULTS=8
MAX_PAGES_PER_SEARCH=3
FETCH_TIMEOUT_MS=8000
SEARCH_LANGUAGE=en-us
# Optional. Leave empty for general search; search_recent passes an explicit window.
SEARCH_RECENCY_WINDOW=

# SearXNG instance URL
SEARXNG_URL=http://localhost:8080
SEARXNG_RETRY_ATTEMPTS=3
SEARXNG_RETRY_DELAY_MS=1500
SEARXNG_RETRY_BACKOFF_MULTIPLIER=2

# Embeddings/reranking model URL
EMBEDDINGS_BASE_URL=http://localhost:8000

# MCP HTTP server
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8787
